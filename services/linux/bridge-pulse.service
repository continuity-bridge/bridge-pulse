[Unit]
Description=Bridge Pulse - Temporal Awareness Service
After=network.target

[Service]
Type=simple
User=tallest
WorkingDirectory=/home/tallest/Claude
Environment="CLAUDE_HOME=/home/tallest/Claude"
ExecStart=/usr/bin/python3 /home/tallest/Claude/scripts/bridge-pulse.py
Restart=always
RestartSec=5

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=bridge-pulse

[Install]
WantedBy=multi-user.target
